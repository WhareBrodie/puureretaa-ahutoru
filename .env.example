# Production defaults — override in Portainer if needed
TZ=Pacific/Auckland
PUBLIC_URL=http://xn--preret-ahutoru-qub40o.internal
PORT=80

# Bambu cloud sync (required for auto-import)
# BAMBU_CLOUD_EMAIL=
# BAMBU_CLOUD_PASSWORD=
# BAMBU_CLOUD_ACCESS_TOKEN=   # MakerWorld cookie named "token" after login at makerworld.com

# Optional — auto-discovered from cloud when omitted
# BAMBU_SERIAL=
# BAMBU_CLOUD_DEVICE_ID=

# Optional local fallback (printer stays cloud-connected; do NOT enable LAN Only Mode)
# BAMBU_PRINTER_IP=
# BAMBU_LAN_ACCESS_CODE=
# BAMBU_MQTT_BROKER=us.mqtt.bambulab.com
# BAMBU_MQTT_MODE=auto
# BAMBU_SYNC_DEDUCT_FILAMENT=true   # false = log Bambu prints without deducting spool weight

# Alert thresholds
DEFAULT_LOW_STOCK_THRESHOLD_G=100
SYNC_CLOUD_INTERVAL_S=300
